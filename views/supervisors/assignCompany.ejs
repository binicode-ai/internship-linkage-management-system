<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Assign Company Supervisor — InternLink</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<%- include('../partials/header') %>

<!-- Progress indicator -->
<div style="background:#fff;border-bottom:1px solid var(--border);padding:16px 32px;display:flex;align-items:center;gap:0;max-width:600px;margin-bottom:28px">
  <div style="display:flex;align-items:center;gap:8px">
    <div style="width:32px;height:32px;border-radius:50%;background:#dcfce7;color:#166534;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem">✓</div>
    <span style="font-size:0.875rem;font-weight:600;color:#166534">University Supervisor</span>
  </div>
  <div style="flex:1;height:2px;background:var(--accent);margin:0 12px"></div>
  <div style="display:flex;align-items:center;gap:8px">
    <div style="width:32px;height:32px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem">2</div>
    <span style="font-size:0.875rem;font-weight:700;color:var(--accent)">Company Supervisor</span>
  </div>
</div>

<div class="page-header">
  <div>
    <h1>Step 2: Assign Company Supervisor</h1>
    <p>
      <strong><%= application.student_name %></strong> — <%= application.internship_title %>
      &nbsp;·&nbsp; Company: <strong><%= application.company_name %></strong>
    </p>
  </div>
  <a href="/supervisors/assign/<%= application.application_id %>" class="btn btn-ghost">← Back to Step 1</a>
</div>

<% if (error) { %>
  <div class="alert alert-error" style="max-width:520px;margin-bottom:20px">⚠️ <%= error %></div>
<% } %>

<% if (existing) { %>
  <div class="alert alert-success" style="max-width:520px;margin-bottom:20px;background:#dcfce7;border:1px solid #bbf7d0;color:#166534;padding:12px 16px;border-radius:8px;font-size:0.875rem">
    ✅ Company supervisor already assigned: <strong><%= existing.full_name %></strong>. You can update below.
  </div>
<% } %>

<div class="form-card" style="max-width:520px">
  <div class="form-card-header"><h2>🏢 Company Supervisor Details</h2></div>
  <div class="form-card-body">
    <form action="/supervisors/assign/<%= application.application_id %>/company" method="POST">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="full_name" placeholder="Ato Kebede Alemu" required value="<%= existing ? existing.full_name : '' %>">
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="supervisor@company.com" required value="<%= existing ? existing.email : '' %>">
      </div>
      <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="phone_number" placeholder="+251 9XX XXX XXX" value="<%= existing && existing.phone_number ? existing.phone_number : '' %>">
      </div>
      <div class="form-group">
        <label>Job Title</label>
        <input type="text" name="job_title" placeholder="e.g. Senior Software Engineer" required value="<%= existing ? existing.job_title : '' %>">
      </div>
      <div class="form-group">
        <label>Company</label>
        <select name="company_id" required>
          <option value="">— Select Company —</option>
          <% companies.forEach(c => { %>
            <option value="<%= c.company_id %>" <%= (existing && existing.company_id == c.company_id) || (!existing && application.company_id == c.company_id) ? 'selected' : '' %>>
              <%= c.company_name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Complete Assignment ✓</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
