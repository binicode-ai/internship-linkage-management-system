<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Apply — InternLink Portal</title>
<link rel="stylesheet" href="/style.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#0f172a;--accent:#3b82f6;--purple:#8b5cf6;--green:#10b981;--bg:#f8fafc;--border:#e2e8f0;--muted:#64748b;--text:#1e293b}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text)}
.portal-layout{display:flex;min-height:100vh}
/* Sidebar */
.sidebar{width:240px;background:var(--navy);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100}
.sidebar-brand{padding:24px 20px;border-bottom:1px solid rgba(255,255,255,0.08)}
.sidebar-brand .name{color:#fff;font-weight:800;font-size:1rem}
.sidebar-brand .sub{color:rgba(255,255,255,0.35);font-size:0.72rem;margin-top:2px}
.sidebar-nav{flex:1;padding:16px 0}
.nav-section{font-size:0.65rem;font-weight:700;color:rgba(255,255,255,0.28);text-transform:uppercase;letter-spacing:0.08em;padding:12px 20px 4px}
.sidebar-nav a{display:flex;align-items:center;gap:10px;padding:10px 20px;color:rgba(255,255,255,0.6);text-decoration:none;font-size:0.875rem;font-weight:500;border-left:3px solid transparent;transition:all 0.15s}
.sidebar-nav a:hover,.sidebar-nav a.active{color:#fff;background:rgba(59,130,246,0.15);border-left-color:var(--accent)}
.sidebar-nav a .ni{font-size:1rem;width:20px;text-align:center;flex-shrink:0}
.sidebar-footer{padding:16px 20px;border-top:1px solid rgba(255,255,255,0.08)}
.sidebar-footer a{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.35);text-decoration:none;font-size:0.8rem;transition:color 0.15s}
.sidebar-footer a:hover{color:#fff}
/* Main */
.main-wrap{margin-left:240px;flex:1;display:flex;flex-direction:column}
.topbar{background:#fff;border-bottom:1px solid var(--border);padding:0 32px;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.topbar-title{font-size:0.95rem;font-weight:600;color:var(--text)}
.user-chip{display:flex;align-items:center;gap:8px;background:#f1f5f9;border-radius:20px;padding:6px 14px 6px 6px}
.user-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--purple));display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.75rem;font-weight:700}
.user-name{font-size:0.82rem;font-weight:600;color:var(--text)}
.page-content{padding:32px;flex:1}
/* Internship cards grid */
.intern-apply-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-top:24px}
.intern-apply-card{background:#fff;border-radius:14px;border:1px solid var(--border);padding:22px;box-shadow:0 2px 8px rgba(0,0,0,0.05);transition:all 0.25s;cursor:pointer;position:relative}
.intern-apply-card:hover{box-shadow:0 8px 28px rgba(59,130,246,0.15);transform:translateY(-3px);border-color:rgba(59,130,246,0.3)}
.intern-apply-card.selected{border-color:var(--accent);box-shadow:0 0 0 3px rgba(59,130,246,0.15)}
.intern-apply-card.selected::after{content:'✓';position:absolute;top:12px;right:12px;width:24px;height:24px;border-radius:50%;background:var(--accent);color:#fff;font-size:0.75rem;font-weight:700;display:flex;align-items:center;justify-content:center}
.iac-title{font-size:0.95rem;font-weight:700;color:var(--text);margin-bottom:4px}
.iac-company{color:var(--accent);font-size:0.82rem;font-weight:600;margin-bottom:12px}
.iac-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.iac-tag{font-size:0.72rem;color:var(--muted);background:#f1f5f9;padding:3px 8px;border-radius:5px}
/* Skeleton */
.skeleton-card{background:#fff;border-radius:14px;border:1px solid var(--border);padding:22px;animation:skeletonShimmer 1.5s infinite}
.sk-line{height:12px;background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200% 100%;border-radius:6px;margin-bottom:10px;animation:skeletonShimmer 1.5s infinite}
@keyframes skeletonShimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
/* Submit bar */
.submit-bar{background:#fff;border-top:1px solid var(--border);padding:16px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;bottom:0;z-index:40}
.submit-bar .selected-info{font-size:0.875rem;color:var(--muted)}
.submit-bar .selected-info strong{color:var(--text)}
@media(max-width:768px){.sidebar{display:none}.main-wrap{margin-left:0}}
</style>
</head>
<body>
<div class="portal-layout">
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="name">🎓 InternLink</div>
      <div class="sub">Student Portal</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Main</div>
      <a href="/portal"><span class="ni">🏠</span> Dashboard</a>
      <a href="/portal/apply" class="active"><span class="ni">💼</span> Apply</a>
      <a href="/portal/complaints"><span class="ni">💬</span> Complaints</a>
      <div class="nav-section">Explore</div>
      <a href="/public/internships" target="_blank"><span class="ni">🔍</span> Browse Internships</a>
      <a href="/public" target="_blank"><span class="ni">🌐</span> Public Site</a>
    </nav>
    <div class="sidebar-footer">
      <a href="/portal/logout">🚪 Sign Out</a>
    </div>
  </aside>

  <div class="main-wrap">
    <header class="topbar">
      <span class="topbar-title">Apply for Internship</span>
      <div style="display:flex;align-items:center;gap:12px">
        <div class="user-chip">
          <div class="user-avatar"><%= studentName.charAt(0) %></div>
          <span class="user-name"><%= studentName %></span>
        </div>
        <a href="/portal/logout" style="font-size:0.8rem;color:var(--muted);text-decoration:none">Sign Out</a>
      </div>
    </header>

    <main class="page-content">
      <div style="margin-bottom:24px">
        <h1 style="font-size:1.4rem;font-weight:800;color:var(--navy);margin-bottom:6px">Available Internships</h1>
        <p style="color:var(--muted);font-size:0.875rem">Select an internship below and click Apply. <a href="/public/internships" target="_blank" style="color:var(--accent)">View full details →</a></p>
      </div>

      <% if (error) { %>
        <div style="background:#fee2e2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:10px;font-size:0.875rem;margin-bottom:20px">⚠️ <%= error %></div>
      <% } %>

      <!-- Skeleton (shown briefly) -->
      <div id="skeleton">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px">
          <% for(var i=0;i<6;i++) { %>
          <div class="skeleton-card">
            <div class="sk-line" style="width:70%"></div>
            <div class="sk-line" style="width:45%;margin-bottom:16px"></div>
            <div class="sk-line" style="width:90%"></div>
            <div class="sk-line" style="width:60%"></div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Real content -->
      <form action="/portal/apply" method="POST" id="applyForm" style="display:none">
        <% if (internships.length === 0) { %>
          <div style="text-align:center;padding:60px;color:var(--muted)">
            <div style="font-size:3rem;margin-bottom:12px">💼</div>
            <p>No internships available right now. <a href="/public/internships" style="color:var(--accent)">Check back soon</a>.</p>
          </div>
        <% } else { %>
        <div class="intern-apply-grid">
          <% internships.forEach(i => { %>
          <label class="intern-apply-card" for="int_<%= i.internship_id %>" onclick="selectCard(this,'<%= i.title %>')">
            <input type="radio" name="internship_id" id="int_<%= i.internship_id %>" value="<%= i.internship_id %>" required style="display:none">
            <div class="iac-title"><%= i.title %></div>
            <div class="iac-company">🏢 <%= i.company_name %></div>
            <div class="iac-tags">
              <span class="iac-tag">⏱ <%= i.duration_months %> mo</span>
              <% if (i.stipend) { %><span class="iac-tag">💰 ETB <%= Number(i.stipend).toLocaleString() %></span><% } %>
              <% if (i.start_date) { %><span class="iac-tag">📅 <%= new Date(i.start_date).toISOString().slice(0,10) %></span><% } %>
            </div>
          </label>
          <% }) %>
        </div>
        <% } %>
      </form>
    </main>

    <div class="submit-bar" id="submitBar" style="display:none">
      <div class="selected-info">Selected: <strong id="selectedTitle">None</strong></div>
      <div style="display:flex;gap:10px">
        <a href="/public/internships" target="_blank" class="btn btn-ghost btn-sm">View Details</a>
        <button type="submit" form="applyForm" class="btn btn-primary" id="submitBtn" disabled>Submit Application →</button>
      </div>
    </div>
  </div>
</div>

<script>
setTimeout(function(){
  document.getElementById('skeleton').style.display='none';
  document.getElementById('applyForm').style.display='block';
  document.getElementById('submitBar').style.display='flex';
},700);

function selectCard(label, title){
  document.querySelectorAll('.intern-apply-card').forEach(function(c){c.classList.remove('selected')});
  label.classList.add('selected');
  document.getElementById('selectedTitle').textContent=title;
  document.getElementById('submitBtn').disabled=false;
}
</script>
</body>
</html>
