<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Student Login — InternLink</title>
<link rel="stylesheet" href="/style.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#0f172a;--accent:#3b82f6;--purple:#8b5cf6}
body{
  font-family:'Segoe UI',system-ui,sans-serif;
  background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  padding:20px;position:relative;overflow:hidden;
}
/* Background blobs */
.bg-blob{position:absolute;border-radius:50%;filter:blur(80px);opacity:0.12;pointer-events:none}
.bg-blob-1{width:500px;height:500px;background:radial-gradient(circle,#3b82f6,#8b5cf6);top:-150px;right:-100px;animation:blobF 8s ease-in-out infinite}
.bg-blob-2{width:350px;height:350px;background:radial-gradient(circle,#06b6d4,#3b82f6);bottom:-100px;left:-80px;animation:blobF 10s ease-in-out infinite 3s}
@keyframes blobF{0%,100%{transform:translate(0,0)}50%{transform:translate(20px,-20px)}}
/* Card */
.auth-card{
  background:rgba(255,255,255,0.04);
  backdrop-filter:blur(24px) saturate(180%);
  -webkit-backdrop-filter:blur(24px) saturate(180%);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:24px;width:100%;max-width:420px;
  box-shadow:0 32px 80px rgba(0,0,0,0.5);
  overflow:hidden;
  animation:cardIn 0.6s cubic-bezier(.4,0,.2,1);
}
@keyframes cardIn{from{opacity:0;transform:translateY(24px) scale(0.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.auth-header{
  background:linear-gradient(135deg,rgba(59,130,246,0.2),rgba(139,92,246,0.2));
  padding:36px 32px 28px;text-align:center;
  border-bottom:1px solid rgba(255,255,255,0.08);
}
.auth-logo{
  width:64px;height:64px;border-radius:18px;
  background:linear-gradient(135deg,var(--accent),var(--purple));
  display:flex;align-items:center;justify-content:center;font-size:1.8rem;
  margin:0 auto 16px;box-shadow:0 0 24px rgba(59,130,246,0.5);
  animation:logoPulse 3s ease-in-out infinite;
}
@keyframes logoPulse{0%,100%{box-shadow:0 0 24px rgba(59,130,246,0.5)}50%{box-shadow:0 0 40px rgba(59,130,246,0.8)}}
.auth-header h1{color:#fff;font-size:1.4rem;font-weight:800;margin-bottom:6px}
.auth-header p{color:rgba(255,255,255,0.55);font-size:0.85rem}
.auth-body{padding:32px}
/* Alert */
.alert-error{background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:12px 16px;border-radius:10px;font-size:0.875rem;margin-bottom:20px;display:flex;align-items:center;gap:8px}
/* Form */
.form-group{margin-bottom:18px}
.form-group label{display:block;font-size:0.75rem;font-weight:700;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:7px}
.form-group input{
  width:100%;padding:12px 16px;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.12);
  border-radius:10px;font-size:0.9rem;color:#fff;
  font-family:inherit;
  transition:all 0.2s;
}
.form-group input::placeholder{color:rgba(255,255,255,0.3)}
.form-group input:focus{
  outline:none;
  border-color:rgba(59,130,246,0.6);
  background:rgba(59,130,246,0.08);
  box-shadow:0 0 0 3px rgba(59,130,246,0.15);
}
/* Submit button */
.btn-submit{
  width:100%;padding:13px;border:none;cursor:pointer;
  background:linear-gradient(135deg,var(--accent),var(--purple));
  color:#fff;border-radius:10px;font-size:0.95rem;font-weight:700;
  font-family:inherit;
  box-shadow:0 0 20px rgba(59,130,246,0.4);
  transition:all 0.25s cubic-bezier(.4,0,.2,1);
  position:relative;overflow:hidden;
}
.btn-submit::before{
  content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);
  animation:shimmer 2.5s infinite;
}
@keyframes shimmer{0%{left:-100%}100%{left:200%}}
.btn-submit:hover{transform:translateY(-2px);box-shadow:0 0 32px rgba(59,130,246,0.65)}
.btn-submit:active{transform:translateY(0) scale(0.98)}
/* Footer links */
.auth-footer{padding:18px 32px;border-top:1px solid rgba(255,255,255,0.07);text-align:center;font-size:0.82rem;color:rgba(255,255,255,0.4)}
.auth-footer a{color:rgba(99,179,237,0.9);text-decoration:none;transition:color 0.2s}
.auth-footer a:hover{color:#fff}
</style>
</head>
<body>
<div class="bg-blob bg-blob-1"></div>
<div class="bg-blob bg-blob-2"></div>

<div class="auth-card">
  <div class="auth-header">
    <div class="auth-logo">🎓</div>
    <h1>Student Portal</h1>
    <p>Sign in to track your internship journey</p>
  </div>
  <div class="auth-body">
    <% if (error) { %>
      <div class="alert-error">⚠️ <%= error %></div>
    <% } %>
    <form action="/portal/login" method="POST">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="your@university.edu.et" required autofocus>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn-submit">Sign In →</button>
    </form>
  </div>
  <div class="auth-footer">
    No account? <a href="/portal/register">Create one</a> &nbsp;·&nbsp; <a href="/public">Browse Internships</a> &nbsp;·&nbsp; <a href="/admin/login">Admin</a>
  </div>
</div>
</body>
</html>
