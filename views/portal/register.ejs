<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Create Account — InternLink</title>
<link rel="stylesheet" href="/style.css">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f9fafb; min-height: 100vh; display: flex; flex-direction: column; }
.reg-header { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 0 40px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
.reg-header .brand { font-weight: 800; font-size: 1rem; color: #111827; text-decoration: none; display: flex; align-items: center; gap: 8px; }
.reg-header .brand-logo { width: 30px; height: 30px; border-radius: 7px; background: linear-gradient(135deg,#2563eb,#7c3aed); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; color: #fff; }
.reg-header .login-link { font-size: 0.875rem; color: #6b7280; }
.reg-header .login-link a { color: #2563eb; text-decoration: none; font-weight: 600; }
.reg-wrap { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 40px 20px; }
.reg-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; width: 100%; max-width: 560px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.07); }
.reg-card-header { background: linear-gradient(135deg,#1e3a8a,#1d4ed8); padding: 28px 32px; }
.reg-card-header h1 { color: #fff; font-size: 1.3rem; font-weight: 800; margin-bottom: 4px; }
.reg-card-header p { color: rgba(255,255,255,0.7); font-size: 0.85rem; }
.reg-card-body { padding: 28px 32px; }
.alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 12px 16px; border-radius: 8px; font-size: 0.875rem; margin-bottom: 20px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-size: 0.75rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
.form-group input, .form-group select { width: 100%; padding: 10px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.9rem; color: #111827; font-family: inherit; transition: border-color 0.15s; background: #fff; }
.form-group input:focus, .form-group select:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
.form-group select option { color: #111827; }
.btn-submit { width: 100%; padding: 12px; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 700; cursor: pointer; font-family: inherit; transition: background 0.15s; margin-top: 4px; }
.btn-submit:hover { background: #1d4ed8; }
.reg-card-footer { padding: 16px 32px; border-top: 1px solid #f3f4f6; text-align: center; font-size: 0.82rem; color: #6b7280; }
.reg-card-footer a { color: #2563eb; text-decoration: none; font-weight: 600; }
.divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
.divider hr { flex: 1; border: none; border-top: 1px solid #e5e7eb; }
.divider span { font-size: 0.78rem; color: #9ca3af; white-space: nowrap; }
@media (max-width: 540px) { .form-row { grid-template-columns: 1fr; } .reg-card-body { padding: 24px 20px; } }
</style>
</head>
<body>
<header class="reg-header">
  <a href="/public" class="brand"><div class="brand-logo">🎓</div> InternLink</a>
  <div class="login-link">Already have an account? <a href="/portal/login<%= next ? '?next='+encodeURIComponent(next) : '' %>">Sign in</a></div>
</header>

<div class="reg-wrap">
  <div class="reg-card">
    <div class="reg-card-header">
      <h1>Create Your Account</h1>
      <p>Register to apply for internships and track your progress</p>
    </div>
    <div class="reg-card-body">
      <% if (error) { %>
        <div class="alert-error">⚠️ <%= error %></div>
      <% } %>

      <form action="/portal/register" method="POST">
        <input type="hidden" name="next" value="<%= next %>">

        <div class="form-row">
          <div class="form-group">
            <label>First Name *</label>
            <input type="text" name="first_name" placeholder="Abebe" required autofocus>
          </div>
          <div class="form-group">
            <label>Last Name *</label>
            <input type="text" name="last_name" placeholder="Bekele" required>
          </div>
        </div>

        <div class="form-group">
          <label>Email Address *</label>
          <input type="email" name="email" placeholder="abebe@university.edu.et" required>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Department *</label>
            <input type="text" name="department" placeholder="e.g. Computer Science" required>
          </div>
          <div class="form-group">
            <label>Year of Study *</label>
            <select name="year_of_study" required>
              <option value="">— Select Year —</option>
              <option value="1">Year 1</option>
              <option value="2">Year 2</option>
              <option value="3">Year 3</option>
              <option value="4">Year 4</option>
              <option value="5">Year 5</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label>University *</label>
          <select name="university_id" required>
            <option value="">— Select Your University —</option>
            <% universities.forEach(u => { %>
              <option value="<%= u.university_id %>"><%= u.university_name %></option>
            <% }) %>
          </select>
        </div>

        <div class="divider"><hr><span>Set your login password</span><hr></div>

        <div class="form-group">
          <label>Password *</label>
          <input type="password" name="password" placeholder="Choose a strong password (min 6 characters)" required minlength="6">
        </div>

        <button type="submit" class="btn-submit">Create Account & Continue →</button>
      </form>
    </div>
    <div class="reg-card-footer">
      By registering, you agree to use InternLink for academic internship purposes. &nbsp;
      <a href="/public">Browse Internships</a>
    </div>
  </div>
</div>
</body>
</html>
