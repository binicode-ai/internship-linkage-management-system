<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Companies — InternLink</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body{margin:0;font-family:'Segoe UI',system-ui,sans-serif;background:#f0f4fa}
    .pub-content{max-width:1100px;margin:0 auto;padding:48px 32px}
    .page-banner{background:linear-gradient(135deg,#0f1f3d,#1e3a6e);color:#fff;padding:48px 40px;border-radius:12px;margin-bottom:36px}
    .page-banner h1{font-size:1.9rem;font-weight:800;margin-bottom:8px}
    .page-banner p{color:rgba(255,255,255,0.7)}
    .companies-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px}
    .company-card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;padding:28px;box-shadow:0 2px 8px rgba(0,0,0,0.06);transition:all 0.2s}
    .company-card:hover{box-shadow:0 8px 24px rgba(79,142,247,0.15);transform:translateY(-2px)}
    .company-card h3{font-size:1rem;font-weight:700;color:#0f1f3d;margin-bottom:4px}
    .company-card .industry{color:#4f8ef7;font-size:0.8rem;font-weight:600;margin-bottom:14px}
    .company-card p{font-size:0.82rem;color:#64748b;margin-bottom:4px}
    .company-card .badge-count{display:inline-block;background:#dbeafe;color:#1e40af;font-size:0.75rem;font-weight:600;padding:3px 10px;border-radius:20px;margin-top:12px}
  </style>
</head>
<body>
<%- include('partials/nav') %>
<div class="pub-content">
  <div class="page-banner">
    <h1>🏢 Partner Companies</h1>
    <p><%= companies.length %> industry partners offering internship opportunities</p>
  </div>
  <% if (companies.length === 0) { %>
    <div style="text-align:center;padding:60px;color:#64748b;">No companies registered yet.</div>
  <% } else { %>
  <div class="companies-grid">
    <% companies.forEach(c => { %>
    <div class="company-card">
      <h3><%= c.company_name %></h3>
      <div class="industry"><%= c.industry_type %></div>
      <p>📍 <%= c.location %></p>
      <p>📧 <%= c.contact_email %></p>
      <p>📞 <%= c.phone_number %></p>
      <div class="badge-count">💼 <%= c.internship_count %> internship<%= c.internship_count != 1 ? 's' : '' %></div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
<%- include('partials/footer') %>
</body>
</html>
