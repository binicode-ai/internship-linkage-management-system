<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Internships — InternLink</title>
<link rel="stylesheet" href="/style.css">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f9fafb; color: #111827; }
.page-hero { background: linear-gradient(135deg,#1e3a8a,#1d4ed8); padding: 48px 60px; }
.page-hero h1 { font-size: 1.9rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
.page-hero p { color: rgba(255,255,255,0.7); }
.content { max-width: 1100px; margin: 0 auto; padding: 40px; }
.intern-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 24px; }
.intern-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); display: flex; flex-direction: column; transition: box-shadow 0.2s, transform 0.2s; }
.intern-card:hover { box-shadow: 0 8px 28px rgba(37,99,235,0.12); transform: translateY(-3px); }
.intern-card h3 { font-size: 1rem; font-weight: 700; color: #111827; margin-bottom: 4px; }
.intern-card .co { color: #2563eb; font-size: 0.83rem; font-weight: 600; margin-bottom: 12px; }
.intern-card .desc { font-size: 0.83rem; color: #6b7280; line-height: 1.6; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.intern-card .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px; }
.intern-card .tag { font-size: 0.73rem; color: #6b7280; background: #f3f4f6; padding: 3px 8px; border-radius: 5px; }
.intern-card .actions { margin-top: auto; display: flex; gap: 8px; }
.btn-apply { background: #2563eb; color: #fff; padding: 9px 20px; border-radius: 7px; font-size: 0.85rem; font-weight: 700; text-decoration: none; transition: background 0.15s; }
.btn-apply:hover { background: #1d4ed8; }
.btn-detail { background: #f3f4f6; color: #374151; padding: 9px 16px; border-radius: 7px; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: background 0.15s; }
.btn-detail:hover { background: #e5e7eb; }
.empty { text-align: center; padding: 80px 20px; color: #9ca3af; }
.empty .ei { font-size: 3rem; margin-bottom: 12px; }
@media (max-width: 768px) { .page-hero { padding: 40px 20px; } .content { padding: 24px 20px; } }
</style>
</head>
<body>
<%- include('public/partials/nav') %>

<div class="page-hero">
  <h1>💼 Available Internships</h1>
  <p><%= internships.length %> opportunities available across Ethiopia</p>
</div>

<div class="content">
  <% if (internships.length === 0) { %>
    <div class="empty">
      <div class="ei">💼</div>
      <p>No internships posted yet. Check back soon.</p>
    </div>
  <% } else { %>
  <div class="intern-grid">
    <% internships.forEach(i => { %>
    <div class="intern-card">
      <h3><%= i.title %></h3>
      <div class="co">🏢 <%= i.company_name %> &nbsp;·&nbsp; 📍 <%= i.location %></div>
      <% if (i.description) { %>
        <div class="desc"><%= i.description %></div>
      <% } %>
      <div class="tags">
        <span class="tag">⏱ <%= i.duration_months %> months</span>
        <% if (i.stipend) { %><span class="tag">💰 ETB <%= Number(i.stipend).toLocaleString() %></span><% } %>
        <% if (i.start_date) { %><span class="tag">📅 <%= new Date(i.start_date).toISOString().slice(0,10) %></span><% } %>
      </div>
      <div class="actions">
        <a href="/public/internships/<%= i.internship_id %>" class="btn-detail">Details</a>
        <a href="/portal/apply" class="btn-apply">Apply Now</a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('public/partials/footer') %>
</body>
</html>
